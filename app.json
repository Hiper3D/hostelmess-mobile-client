{
  "expo": {
    "name": "HostelMess",
    "slug": "HotelMess",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff",
            "image": "./assets/splash-icon.png"
          },
          "imageWidth": 180
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#ffffff",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.hiper_3d.hostelmess"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "558aba74-402d-4f1e-94c9-d1d270ecb73b"
      }
    }
  }
}